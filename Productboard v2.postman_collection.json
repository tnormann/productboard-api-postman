              ],
              "path": [
                "entities",
                "{{entity_id}}",
                "relationships",
                "{{relationship_type}}",
                "{{relationship_target_id}}"
              ]
            },
            "description": "Live-proved on 2026-03-06 for deleting `isBlockedBy` and `isBlocking` relationships between sibling features. Deleting required parents still fails by business rule."
          }
        }
